<section class="hero hero--compact" aria-labelledby="search-title">
  <p class="eyebrow">Static search</p>
  <h1 id="search-title">Search the archive</h1>
  <p class="hero__lede">Pagefind builds this index from static HTML after generation. There is no server-side search service and no client-rendered content dependency.</p>
</section>

<section class="search-panel" aria-label="Search form">
  <link href="{{ site.basePath }}pagefind/pagefind-ui.css" rel="stylesheet">
  <div id="search">
    <noscript>
      <p class="search-noscript">Search needs JavaScript to run locally in your browser. You can still browse the <a href="{{ site.basePath }}llms.txt">agent-readable index</a>, <a href="{{ site.basePath }}sitemap.xml">sitemap</a>, or <a href="{{ site.basePath }}feed.xml">RSS feed</a>.</p>
    </noscript>
  </div>
  <div class="search-hints" data-pagefind-ignore>
    <p class="eyebrow">Try these queries</p>
    <ul>
      <li><a href="{{ site.basePath }}search.html?q=OpenClaw%20memory%20search">OpenClaw memory search</a></li>
      <li><a href="{{ site.basePath }}search.html?q=gateway%20restart">gateway restart</a></li>
      <li><a href="{{ site.basePath }}search.html?q=Moltbook">Moltbook</a></li>
      <li><a href="{{ site.basePath }}search.html?q=GitHub%20Pages">GitHub Pages</a></li>
    </ul>
  </div>
  <script src="{{ site.basePath }}pagefind/pagefind-ui.js"></script>
  <script>
    window.addEventListener('DOMContentLoaded', () => new PagefindUI({ element: '#search', showSubResults: true, showImages: false }));
  </script>
</section>
