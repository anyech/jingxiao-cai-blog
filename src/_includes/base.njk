<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="{{ site.author }}">
    <meta name="description" content="{{ description or site.description }}">
    <meta name="robots" content="{{ robots or 'index,follow,max-image-preview:large' }}">
    <meta name="theme-color" content="#0f172a">
    {% if site.googleSiteVerification %}<meta name="google-site-verification" content="{{ site.googleSiteVerification }}">{% endif %}
    <link rel="canonical" href="{{ site.url }}{{ site.basePath }}{{ canonicalPath or (slug + '.html' if slug else '') }}">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS Feed" href="{{ site.url }}{{ site.basePath }}feed.xml">
    <link rel="alternate" type="text/plain" title="LLMs text overview" href="{{ site.url }}{{ site.basePath }}llms.txt">
    {% if slug %}<link rel="alternate" type="text/markdown" title="Markdown mirror" href="{{ site.url }}{{ site.basePath }}{{ slug }}.html.md">{% endif %}
    <link rel="sitemap" type="application/xml" href="{{ site.url }}{{ site.basePath }}sitemap.xml">
    <link rel="icon" href="{{ site.basePath }}favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="{{ site.basePath }}assets/site.css">
    <meta property="og:type" content="{{ ogType or ('article' if slug else 'website') }}">
    <meta property="og:title" content="{{ title or site.title }}">
    <meta property="og:description" content="{{ description or summary or site.description }}">
    <meta property="og:url" content="{{ site.url }}{{ site.basePath }}{{ canonicalPath or (slug + '.html' if slug else '') }}">
    <meta property="og:site_name" content="{{ site.title }}">
    <meta property="og:image" content="{{ site.image }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title or site.title }}">
    <meta name="twitter:description" content="{{ description or summary or site.description }}">
    <meta name="twitter:image" content="{{ site.image }}">
    {% if slug %}
    <script type="application/ld+json">{{ {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description or summary,
      "author": {"@type": "Person", "name": site.author, "url": site.authorUrl},
      "publisher": {"@type": "Person", "name": site.author, "url": site.authorUrl},
      "datePublished": date,
      "dateModified": updated or date,
      "url": site.url + site.basePath + slug + '.html',
      "image": site.image,
      "mainEntityOfPage": site.url + site.basePath + slug + '.html'
    } | json | safe }}</script>
    {% else %}
    <script type="application/ld+json">{{ {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": site.title,
      "url": site.url + site.basePath,
      "description": site.description,
      "inLanguage": "en-US",
      "author": {"@type": "Person", "name": site.author, "url": site.authorUrl, "sameAs": site.sameAs},
      "publisher": {"@type": "Person", "name": site.author, "url": site.authorUrl}
    } | json | safe }}</script>
    {% endif %}
    <title>{{ title or site.title }}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header" data-pagefind-ignore>
      <div class="site-header__inner">
        <a class="brand" href="{{ site.basePath }}" aria-label="{{ site.title }} home">
          <span class="brand__mark">JC</span>
          <span class="brand__text">Jingxiao Cai</span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="{{ site.basePath }}">Home</a>
          <a href="{{ site.basePath }}search.html">Explore</a>
          <a href="{{ site.basePath }}topics.html">Topics</a>
          <a href="{{ site.authorUrl }}">About</a>
          <a href="{{ site.basePath }}feed.xml">RSS</a>
        </nav>
      </div>
    </header>
    <main id="content" class="site-main">
      {{ content | safe }}
    </main>
  </body>
</html>
