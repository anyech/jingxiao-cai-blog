---
layout: base.njk
permalink: index.html
title: "Jingxiao Cai's Blog | Distributed ML Runtime Systems, Agent Ops, Self-Hosted AI"
description: "Technical blog by Jingxiao Cai about distributed ML runtime systems, backend execution reliability, self-hosted AI agents, debugging, automation, and production engineering."
canonicalPath: ""
---
{% from "post-card.njk" import postCard %}
{% set latestPost = collections.postsByPublished[0] %}
<section class="home-hero" aria-labelledby="site-title">
  <div class="hero hero--home">
    <p class="eyebrow">distributed ML runtime systems · agent ops · self-hosted AI</p>
    <h1 id="site-title">Engineering notes from systems that have to work</h1>
    <p class="hero__lede">Deep dives on distributed execution, backend/runtime reliability, self-hosted AI agents, debugging, and evidence-driven engineering workflows.</p>
    <div class="hero__actions" data-pagefind-ignore>
      <a class="button button--primary" href="{{ site.basePath }}search.html">Explore all posts</a>
      <a class="button" href="{{ site.basePath }}feed.xml">RSS feed</a>
    </div>
  </div>

  <aside class="author-card" aria-labelledby="author-card-title" data-pagefind-ignore>
    <div class="author-card__identity">
      <div class="author-card__monogram" aria-hidden="true">JC</div>
      <div>
        <p class="eyebrow">About the author</p>
        <h2 id="author-card-title">{{ site.author }}</h2>
        <p class="author-card__role">{{ site.authorProfile.role }}</p>
      </div>
    </div>
    <p>{{ site.authorProfile.homepageBio or site.authorProfile.bio }}</p>
    <ul class="profile-links" aria-label="Jingxiao Cai profiles">
      {% for link in site.authorProfile.links %}<li><a href="{{ link.url }}">{{ link.label }}</a></li>{% endfor %}
    </ul>
    {% if latestPost %}
    <div class="author-card__latest">
      <p class="eyebrow">Latest publication</p>
      <a href="{{ site.basePath }}{{ latestPost.data.slug }}.html">{{ latestPost.data.title | safe }}</a>
      <span>{{ latestPost.data.date | dateDisplay }}</span>
    </div>
    {% endif %}
  </aside>
</section>

<section class="home-topics" aria-labelledby="topics-title">
  <div class="section-heading section-heading--split">
    <div><p class="eyebrow">Start with a subject</p><h2 id="topics-title">Browse by topic</h2></div>
    <a class="text-link" href="{{ site.basePath }}topics.html">View topic archive →</a>
  </div>
  <div class="topic-grid">
    {% for topic in topics %}
    {% set topicPosts = collections.postsByPublished | byTopic(topic.slug) %}
    <a class="topic-card" href="{{ site.basePath }}topics/{{ topic.slug }}.html">
      <span class="topic-card__count">{{ topicPosts.length }} post{% if topicPosts.length != 1 %}s{% endif %}</span>
      <strong>{{ topic.label }}</strong>
      <span>{{ topic.description }}</span>
    </a>
    {% endfor %}
  </div>
</section>

<section class="post-list" aria-labelledby="posts-title">
  <div class="section-heading section-heading--split">
    <div><p class="eyebrow">Newest by publication date</p><h2 id="posts-title">Latest publications</h2></div>
    <a class="text-link" href="{{ site.basePath }}search.html">Search and filter →</a>
  </div>
  <div class="post-grid">
  {% for post in collections.postsByPublished | limit(9) %}{{ postCard(post, site, topics) }}{% endfor %}
  </div>
</section>

{% if collections.recentlyUpdated.length %}
<section class="updated-strip" aria-labelledby="updated-title">
  <div class="section-heading"><p class="eyebrow">Meaningful revisions</p><h2 id="updated-title">Recently updated</h2></div>
  <div class="updated-list">
  {% for post in collections.recentlyUpdated | limit(4) %}
    <a href="{{ site.basePath }}{{ post.data.slug }}.html"><strong>{{ post.data.title | safe }}</strong><span>Updated {{ post.data.updated | dateDisplay }}</span></a>
  {% endfor %}
  </div>
</section>
{% endif %}

<section class="agent-note" aria-labelledby="agent-note-title">
  <h2 id="agent-note-title">Built for readers, crawlers, and agents</h2>
  <p>Every post is readable as static HTML with a stable URL. The site also publishes <a href="{{ site.basePath }}feed.xml">RSS</a>, a <a href="{{ site.basePath }}sitemap.xml">sitemap</a>, Markdown mirrors, Pagefind search, and an <a href="{{ site.basePath }}llms.txt"><code>llms.txt</code> index</a>.</p>
</section>

<footer class="page-footer" data-pagefind-ignore>
  <p><a href="https://github.com/anyech/jingxiao-cai-blog">Source on GitHub</a> · <a href="{{ site.basePath }}llms.txt">llms.txt</a></p>
</footer>
